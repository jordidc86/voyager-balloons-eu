# Storage. SQLite is suitable for local development; Railway should use Postgres.
SEO_MONITOR_DATABASE_URL=sqlite:///data/seo-monitor/seo-monitor.db
SEO_MONITOR_CONFIG=config/seo-monitor.json
SEO_MONITOR_KEYWORDS=config/strategic-keywords.csv

# Google service account. Add its email as viewer in Search Console and GA4.
GOOGLE_SERVICE_ACCOUNT_JSON=
GSC_PROPERTY=sc-domain:voyagerballoons.eu
GA4_PROPERTY_ID=

# Pay-as-you-go competitive SERP data.
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Optional PageSpeed key.
PAGESPEED_API_KEY=

# Alert delivery. Secrets belong in Railway, never in git.
SEO_ALERT_EMAIL_TO=
SEO_MONITOR_HEARTBEAT_URL=
SMTP_HOST=
SMTP_PORT=587
# Existing Voyager services use SMTP_USER/SMTP_APP_PASSWORD. The monitor also
# accepts SMTP_USERNAME/SMTP_PASSWORD for providers using those names.
SMTP_USER=
SMTP_APP_PASSWORD=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=info@voyagerballoons.eu
SMTP_SSL=false
SMTP_STARTTLS=true

# Worker controls.
SEO_MONITOR_POLL_SECONDS=60
SEO_MONITOR_DRY_RUN=false
