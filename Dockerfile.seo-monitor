FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app
RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates nodejs \
    && rm -rf /var/lib/apt/lists/*
COPY requirements-seo-monitor.txt ./
RUN pip install --no-cache-dir -r requirements-seo-monitor.txt
COPY . .

CMD ["python", "-m", "seo_monitor", "tick"]
