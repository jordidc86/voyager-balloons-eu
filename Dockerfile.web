FROM python:3.12-alpine AS config

WORKDIR /build
COPY netlify.toml scripts/generate-nginx-config.py ./
RUN python generate-nginx-config.py --input netlify.toml --output default.conf

FROM nginx:1.27-alpine

COPY --from=config /build/default.conf /etc/nginx/conf.d/default.conf
COPY articulos /usr/share/nginx/html/articulos
COPY assets /usr/share/nginx/html/assets
COPY css /usr/share/nginx/html/css
COPY en /usr/share/nginx/html/en
COPY js /usr/share/nginx/html/js
COPY pt /usr/share/nginx/html/pt
COPY *.html *.txt *.xml *.png *.ico *.svg /usr/share/nginx/html/

EXPOSE 80
HEALTHCHECK --interval=30s --timeout=5s --start-period=5s --retries=3 \
    CMD wget -q -O /dev/null http://127.0.0.1/__health || exit 1
